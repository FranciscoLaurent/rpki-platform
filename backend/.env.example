# ===== 应用配置 =====
APP_NAME=RPKI Platform Backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ===== 数据库 PostgreSQL =====
POSTGRES_USER=rpki
POSTGRES_PASSWORD=<CHANGE_ME_TO_A_STRONG_PASSWORD>
POSTGRES_DB=rpki_platform
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://rpki:<CHANGE_ME_TO_A_STRONG_PASSWORD>@localhost:5432/rpki_platform

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== Kafka (RedPanda) =====
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_BGP_EVENTS=bgp-events
KAFKA_TOPIC_ALERTS=rpki-alerts
KAFKA_CONSUMER_GROUP=rpki-platform

# ===== ClickHouse =====
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=rpki_platform

# ===== JWT 安全 =====
JWT_SECRET_KEY=<CHANGE_ME_TO_A_RANDOM_SECRET_KEY>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== CORS =====
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ===== 初始管理员 =====
FIRST_SUPERUSER_USERNAME=admin
FIRST_SUPERUSER_PASSWORD=<CHANGE_ME_TO_A_STRONG_PASSWORD>
FIRST_SUPERUSER_EMAIL=admin@example.com
