# ============================================================
# RPKI 网络安全管理平台 - 生产环境配置模板
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env.production
#   2. 替换所有 <CHANGE_ME> 占位符为实际值
#   3. 使用 docker-compose --env-file .env.production 启动
#
# 安全提示：
#   - 所有密码与密钥必须使用强随机值（建议 openssl rand -hex 32）
#   - 切勿将此文件提交到版本控制系统
#   - 定期轮换密钥（建议每 90 天）
# ============================================================

# ===== 应用基础配置 =====
APP_NAME=RPKI 网络安全管理平台
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# ===== 数据库 PostgreSQL =====
# 必须修改：使用强随机密码
POSTGRES_USER=rpki
POSTGRES_PASSWORD=<CHANGE_ME_USE_openssl_rand_hex_32>
POSTGRES_DB=rpki_platform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://rpki:<CHANGE_ME_USE_openssl_rand_hex_32>@postgres:5432/rpki_platform

# 数据库连接池
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ===== Redis =====
# 必须修改：使用强随机密码
REDIS_PASSWORD=<CHANGE_ME_USE_openssl_rand_hex_32>
REDIS_URL=redis://:<CHANGE_ME_USE_openssl_rand_hex_32>@redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# ===== Kafka =====
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_BGP_EVENTS=bgp-events
KAFKA_TOPIC_ALERTS=rpki-alerts
KAFKA_TOPIC_ROA_CHANGES=roa-changes
KAFKA_CONSUMER_GROUP=rpki-platform
KAFKA_NUM_PARTITIONS=6
KAFKA_REPLICATION_FACTOR=1

# ===== ClickHouse =====
# 必须修改：使用强随机密码
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=rpki
CLICKHOUSE_PASSWORD=<CHANGE_ME_USE_openssl_rand_hex_32>
CLICKHOUSE_DATABASE=rpki_platform

# ===== JWT 安全 =====
# 必须修改：使用 64 字节随机字符串（openssl rand -hex 32）
SECRET_KEY=<CHANGE_ME_USE_openssl_rand_hex_32>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# 旧密钥列表（用于密钥轮换平滑过渡，逗号分隔）
PREVIOUS_SECRET_KEYS=

# ===== 登录安全 =====
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15

# ===== TLS/mTLS 配置 =====
TLS_ENABLED=true
TLS_CERT_FILE=/etc/rpki/ssl/cert.pem
TLS_KEY_FILE=/etc/rpki/ssl/key.pem
TLS_CA_PATH=/etc/rpki/ssl/ca.pem
TLS_MIN_VERSION=TLSv1.2

# RTR 服务 mTLS
MTLS_ENABLED=true
MTLS_CA_FILE=/etc/rpki/mtls/ca.pem
MTLS_CA_PATH=/etc/rpki/mtls/
MTLS_CLIENT_CERT_REQUIRED=true

# ===== IP 白名单 =====
IP_WHITELIST_ENABLED=false
IP_WHITELIST=10.0.0.0/8,192.168.0.0/16
IP_WHITELIST_PATHS=/api/v1/admin,/api/v1/users

# ===== 密钥轮换 =====
SECRET_KEY_ROTATION_INTERVAL_DAYS=90
KEY_ROTATION_INTERVAL_DAYS=90

# ===== 敏感数据加密 =====
# Fernet 密钥（留空则按 SECRET_KEY 派生）
# 生成方法：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
FIELD_ENCRYPTION_KEY=

# ===== 异常登录检测 =====
ANOMALOUS_LOGIN_OFFICE_HOURS_START=8
ANOMALOUS_LOGIN_OFFICE_HOURS_END=18
ANOMALOUS_LOGIN_NEW_GEO_THRESHOLD=0

# ===== 注册配置 =====
OPEN_REGISTRATION=false

# ===== 初始管理员 =====
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=<CHANGE_ME_FIRST_LOGIN>
DEFAULT_ADMIN_EMAIL=admin@rpki.local

# ===== CORS 配置 =====
# 必须修改：填写实际前端域名
CORS_ORIGINS=https://rpki.example.com

# ===== 速率限制 =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_AUTH=10/minute

# ===== RPKI 同步配置 =====
RPKI_SYNC_INTERVAL_SECONDS=3600
RPKI_VALIDATOR_URI=https://rpki-validator.example.com
RPKI_VALIDATOR_TIMEOUT=30

# ===== BGP 采集配置 =====
BGP_COLLECTOR_INTERVAL_SECONDS=60
BGP_RIPE_RIS_ENABLED=true
BGP_ROUTEVIEWS_ENABLED=true
BGP_BMP_ENABLED=false

# ===== 检测引擎配置 =====
DETECTION_ENABLED=true
DETECTION_BATCH_SIZE=1000
DETECTION_WORKERS=4

# ===== 告警配置 =====
ALERT_NOTIFICATION_ENABLED=true
ALERT_WEBHOOK_URL=https://hooks.example.com/rpki-alerts
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_SMTP_USER=
ALERT_EMAIL_SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@rpki.example.com
ALERT_EMAIL_TO=noc@rpki.example.com

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/rpki/backend.log
LOG_MAX_SIZE_MB=50
LOG_BACKUP_COUNT=10

# ===== 前端配置 =====
FRONTEND_HOST=rpki.example.com
FRONTEND_PORT=80

# ===== 备份配置 =====
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/var/backups/rpki
